public class CastError {
    public static void handle(Object obj) {
        Double d = (Double) obj;
        System.out.println(d);
    }

    public static void main(String[] args) {
        Object realDouble = 15.5;
        Object notADouble = "Hello";
        
        handle(realDouble);
        handle(notADouble);
    }
}

