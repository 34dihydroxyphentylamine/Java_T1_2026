public class ParseError {
    public static void transform(String data) {
        int number = Integer.parseInt(data);
        System.out.println(number);
    }

    public static void main(String[] args) {
        String numeric = "500";
        String nonNumeric = "Test";
        
        transform(numeric);
        transform(nonNumeric);
    }
}

