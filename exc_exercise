public class ArrayError {
    public static void access(int index) {
        int[] data = {10, 20, 30};
        int result = data[index];
        System.out.println(result);
    }

    public static void main(String[] args) {
        int validIndex = 1;
        int invalidIndex = 10;
        
        access(validIndex);
        access(invalidIndex);
    }
}


