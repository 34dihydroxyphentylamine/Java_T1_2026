public class MathError {
    public static void calculate(int value) {
        int output = 50 / value;
        System.out.println(output);
    }

    public static void main(String[] args) {
        int normalValue = 5;
        int zeroValue = 0;
        
        calculate(normalValue);
        calculate(zeroValue);
    }
}

